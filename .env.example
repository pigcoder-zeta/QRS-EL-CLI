# 复制此文件为 .env 并填写真实值
# Windows: copy .env.example .env
# Linux/Mac: cp .env.example .env

# ── LLM 配置（必填）────────────────────────────────────────────────
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# 第三方兼容接口地址（可选，使用官方 OpenAI 时无需填写）
# OPENAI_BASE_URL=https://your-api-endpoint/v1

# 模型名称（可选）
# OPENAI_MODEL=gpt-4o

# ── LLM 并发与超时 ────────────────────────────────────────────────
# 最大并发 LLM 请求数（防止 429 限流，默认 6）
# LLM_MAX_CONCURRENT=6

# Agent-R LLM 调用超时秒数（默认 120）
# AGENT_R_TIMEOUT=120

# Agent-R 最大生成 token 数（默认 4096）
# AGENT_R_MAX_TOKENS=4096

# ── Web Dashboard ─────────────────────────────────────────────────
# Flask session 密钥（生产环境务必设置固定值）
# FLASK_SECRET_KEY=your-secret-key-here

# Web API 鉴权密钥（空=不启用鉴权）
# ARGUS_API_KEY=

# API 速率限制（每 IP 每分钟最大请求数，默认 30）
# ARGUS_RATE_LIMIT=30
